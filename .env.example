# Database Configuration
DATABASE_URL=postgresql://root:password@localhost:5432/boltline

# Authentication
JWT_SECRET=dev-secret-key-not-for-production

# Service URLs (for inter-service communication)
GRAPHQL_PORT=4000
EXPRESS_PORT=5000
GRAPHQL_URL=http://localhost:4000/graphql
GRAPHQL_INTERNAL_URL=http://backend-graphql:4000/graphql
EXPRESS_URL=http://localhost:5000
EXPRESS_INTERNAL_URL=http://backend-express:5000
EXPRESS_EVENT_URL=http://localhost:5000/events/emit

# Event Bus Authentication (shared secret for GraphQL → Express communication)
# CRITICAL: Change this value in production. Use strong, randomly generated secrets.
EXPRESS_EVENT_SECRET=change-this-in-production-use-strong-random-secret
FRONTEND_URL=http://localhost:3000

# Next.js Frontend Environment Variables (public)
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql
NEXT_PUBLIC_EXPRESS_URL=http://localhost:5000

# Node Environment
NODE_ENV=development

# Logging
LOG_LEVEL=debug

# File Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Real-time Events
SSE_HEARTBEAT_INTERVAL=30000

# GraphQL
GRAPHQL_INTROSPECTION=true

# Phase D: Frontend SSE Enhancement
# Exponential backoff reconnection: max 10 attempts, base 1s, max 30s
# Formula: delay = min(baseDelay * (2 ^ attemptNumber), maxDelay)
NEXT_PUBLIC_SSE_RECONNECT_MAX_ATTEMPTS=10
NEXT_PUBLIC_SSE_BASE_RETRY_DELAY_MS=1000
NEXT_PUBLIC_SSE_MAX_RETRY_DELAY_MS=30000

# Event deduplication: sliding window of 1000 events, 5-min TTL
NEXT_PUBLIC_SSE_DEDUP_WINDOW_SIZE=1000
NEXT_PUBLIC_SSE_DEDUP_TTL_MS=300000

# Debug mode: Set to 'true' to enable console logging and metrics collection
# Metrics available at window.__SSE_METRICS
NEXT_PUBLIC_SSE_DEBUG=false
