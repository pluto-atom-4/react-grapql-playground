# Backend GraphQL Server Environment Configuration
# Copy to .env.local and customize for your environment

# ==============================================================================
# Database Configuration
# ==============================================================================
DATABASE_URL=postgresql://root:password@localhost:5432/boltline

# ==============================================================================
# Authentication
# ==============================================================================
JWT_SECRET=dev-secret-key-not-for-production

# ==============================================================================
# Service Configuration
# ==============================================================================
GRAPHQL_PORT=4000
NODE_ENV=development
LOG_LEVEL=debug

# ==============================================================================
# Inter-Service URLs (for GraphQL to call Express)
# ==============================================================================
# Local development
EXPRESS_URL=http://localhost:5000
EXPRESS_INTERNAL_URL=http://backend-express:5000

# ==============================================================================
# Event Bus Configuration (Issue #7: Cross-Layer Event Bus)
# GraphQL emits events to Express /events/emit endpoint
# ==============================================================================

# URL where Express is listening for events from GraphQL resolvers
EXPRESS_EVENT_URL=http://localhost:5000/events/emit

# Shared secret for authenticating GraphQL → Express event emission requests
# CRITICAL: Change this in production. Use a strong, randomly generated value.
# Example: openssl rand -base64 32
EXPRESS_EVENT_SECRET=dev-event-secret-change-in-production

# Timeout for event emission HTTP requests (milliseconds)
# If Express event endpoint doesn't respond within this time, emit fails silently
EVENT_EMIT_TIMEOUT_MS=5000

# Maximum retry attempts for emitting events
# If initial emit fails due to network error, retry up to this many times
EVENT_EMIT_MAX_RETRIES=3

# ==============================================================================
# GraphQL Configuration
# ==============================================================================
GRAPHQL_INTROSPECTION=true

# ==============================================================================
# Frontend URLs (for CORS and client configuration)
# ==============================================================================
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql
NEXT_PUBLIC_EXPRESS_URL=http://localhost:5000
