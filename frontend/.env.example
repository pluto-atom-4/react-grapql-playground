# Frontend (Next.js) Environment Configuration
# Copy to .env.local and customize for your environment

# ==============================================================================
# GraphQL API Configuration
# ==============================================================================

# GraphQL server endpoint (for Apollo Client)
# Must be accessible from browser
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql

# ==============================================================================
# Express Server Configuration
# ==============================================================================

# Express server base URL (for file uploads, real-time events)
# Must be accessible from browser
NEXT_PUBLIC_EXPRESS_URL=http://localhost:5000

# ==============================================================================
# Real-Time Event Streaming (Server-Sent Events Configuration)
# (Issue #7: Cross-Layer Event Bus)
# ==============================================================================

# Maximum retry attempts when SSE connection drops
# After max attempts, give up and stop listening for events
# Default: 10 attempts
NEXT_PUBLIC_SSE_RECONNECT_MAX_ATTEMPTS=10

# Base retry delay for SSE reconnection (milliseconds)
# Actual delay uses exponential backoff: base * (2 ^ retry_count)
# Example: base=1000ms → 1s, 2s, 4s, 8s, 16s (for 5 retries)
# Default: 1000ms (1 second)
NEXT_PUBLIC_SSE_BASE_RETRY_DELAY_MS=1000

# ==============================================================================
# Test Configuration (for E2E tests and manual testing)
# ==============================================================================

# Test account credentials (for Playwright E2E tests)
TEST_EMAIL=test@example.com
TEST_PASSWORD=TestPass123

# ==============================================================================
# Environment
# ==============================================================================
NODE_ENV=development
