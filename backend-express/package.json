{
  "name": "backend-express",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,json,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "express": "^4.21.1",
    "multer": "^2.1.1",
    "jsonwebtoken": "^9.0.3",
    "dotenv": "^16.4.5",
    "cors": "^2.8.5",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "@types/node": "^20.11.5",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.1.1",
    "@typescript-eslint/eslint-plugin": "^8.1.0",
    "@typescript-eslint/parser": "^8.1.0",
    "prettier": "^3.1.1",
    "vitest": "^2.0.5",
    "@vitest/ui": "^2.0.5",
    "supertest": "^7.0.0",
    "@types/supertest": "^2.0.12",
    "ts-node": "^10.9.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
