# Backend Express Server Environment Configuration
# Copy to .env.local and customize for your environment

# ==============================================================================
# Express Server Configuration
# ==============================================================================
EXPRESS_PORT=5000
NODE_ENV=development
LOG_LEVEL=debug

# ==============================================================================
# Event Bus Configuration (Issue #7: Cross-Layer Event Bus)
# Express receives events from GraphQL, relays/deduplicates, broadcasts to SSE
# ==============================================================================

# Shared secret for authenticating GraphQL → Express event emission requests
# CRITICAL: Must match EXPRESS_EVENT_SECRET in backend-graphql/.env
# Use a strong, randomly generated value in production.
# Example: openssl rand -base64 32
EXPRESS_EVENT_SECRET=dev-event-secret-change-in-production

# Deduplication: Maximum number of events to keep in memory
# Uses LRU (Least Recently Used) eviction when full
EVENT_DEDUP_WINDOW_SIZE=1000

# Deduplication: Time-to-live for event IDs (milliseconds)
# Events older than this TTL are removed from dedup set
# Default: 5 minutes (300,000ms) - balances memory usage with dedup effectiveness
EVENT_DEDUP_TTL_MS=300000

# ==============================================================================
# Real-Time Event Streaming (Server-Sent Events)
# ==============================================================================

# Heartbeat interval for SSE connections (milliseconds)
# Sends empty comments to keep connection alive and detect dead clients
# Default: 30 seconds
HEARTBEAT_INTERVAL_MS=30000

# Connection timeout for SSE clients (milliseconds)
# If client doesn't send heartbeat acknowledgment within this time, connection closes
# Default: 2 minutes
CONNECTION_TIMEOUT_MS=120000

# ==============================================================================
# File Upload Configuration
# ==============================================================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760  # 10MB in bytes

# ==============================================================================
# Service URLs (for inter-service communication)
# ==============================================================================
GRAPHQL_PORT=4000
GRAPHQL_URL=http://localhost:4000/graphql
GRAPHQL_INTERNAL_URL=http://backend-graphql:4000/graphql
FRONTEND_URL=http://localhost:3000

# ==============================================================================
# Frontend Environment Variables (passed to frontend)
# ==============================================================================
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql
NEXT_PUBLIC_EXPRESS_URL=http://localhost:5000
